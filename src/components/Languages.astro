---
import resume from "@/data/resume";
---



<section id="languages" class="py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
    <h2 class="text-3xl font-bold text-primary mb-2">Languages</h2>
    <div class="w-16 h-1 bg-accent mb-8 rounded-full"></div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {resume.languages.map((lang) => (
        <div class="bg-card border border-border rounded-xl p-5 shadow-sm text-center">
          <p class="text-lg font-semibold text-primary">{lang.name}</p>
          <p class="text-sm text-muted mt-1">{lang.level}</p>
        </div>
      ))}
    </div>
  </div>
</section>
