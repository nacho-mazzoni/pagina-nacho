---
import resume from "@/data/resume";
---

<section id="education" class="py-20 bg-section-alt">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
    <h2 class="text-3xl font-bold text-primary mb-2">Education</h2>
    <div class="w-16 h-1 bg-accent mb-8 rounded-full"></div>
    <div class="space-y-6">
      {resume.education.map((edu) => (
        <div class="bg-card border border-border rounded-xl p-6 shadow-sm">
          <span class="inline-block text-sm font-medium text-accent mb-1">{edu.period}</span>
          <h3 class="text-xl font-bold text-primary">{edu.degree}</h3>
          <p class="text-base font-medium text-primary-light mb-2">{edu.institution}</p>
          {edu.description && <p class="text-muted">{edu.description}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
