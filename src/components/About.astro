---
import resume from "@/data/resume";
---

<section id="about" class="py-20 bg-section-alt">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
    <h2 class="text-3xl font-bold text-primary mb-2">About Me</h2>
    <div class="w-16 h-1 bg-accent mb-8 rounded-full"></div>
    <div class="max-w-3xl">
      <p class="text-lg text-muted leading-relaxed whitespace-pre-line">{resume.about}</p>
    </div>
  </div>
</section>
