---
import resume from "@/data/resume";
---

<section id="blog" class="py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
    <h2 class="text-3xl font-bold text-primary mb-2">Blog</h2>
    <div class="w-16 h-1 bg-accent mb-8 rounded-full"></div>
    <div class="space-y-6">
      {resume.blog.map((post) => (
        <div class="bg-card border border-border rounded-xl p-6 shadow-sm">
          <span class="text-sm text-muted">{post.date}</span>
          <h3 class="text-xl font-bold text-primary mt-1 mb-2">{post.title}</h3>
          <p class="text-muted mb-3">{post.excerpt}</p>
          {post.url && (
            <a href={post.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm font-medium text-accent hover:text-primary-light transition-colors">
              Read more
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
