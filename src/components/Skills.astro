---
import resume from "@/data/resume";

const grouped = resume.skills.reduce(
  (acc, skill) => {
    if (!acc[skill.category]) acc[skill.category] = [];
    acc[skill.category].push(skill);
    return acc;
  },
  {} as Record<string, typeof resume.skills>
);
---

<section id="skills" class="py-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
    <h2 class="text-3xl font-bold text-primary mb-2">Skills</h2>
    <div class="w-16 h-1 bg-accent mb-8 rounded-full"></div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {Object.entries(grouped).map(([category, skills]) => (
        <div>
          <h3 class="text-lg font-semibold text-primary mb-4">{category}</h3>
          <div class="flex flex-wrap gap-2">
            {skills.map((skill) => (
              <span class="px-3 py-1 text-sm font-medium bg-primary-light/10 text-primary-light rounded-full">
                {skill.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
